# ── AI Generation ──────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-3.1-pro-preview"          # optional, defaults to gemini-3.1-pro-preview

# Switch AI provider: "gemini" (default) or "groq"
AI_PROVIDER="gemini"
GROQ_API_KEY=""
GROQ_MODEL=""                                    # required when AI_PROVIDER=groq

# ── RAG (Retrieval-Augmented Generation) ──────────────────
RAG_ENABLED="false"                              # set to "true" to enable RAG context
RAG_PROVIDER="wikipedia"                         # "wikipedia" (default) or "tavily"
RAG_MAX_SOURCES="4"
RAG_MAX_CHARS="2500"
TAVILY_API_KEY=""                                # required when RAG_PROVIDER=tavily

# ── Authentication & Admin ────────────────────────────────
JWT_SECRET="techwiki_dev_secret"                 # change in production!
ADMIN_EMAIL=""                                   # auto-create admin user on first boot
ADMIN_PASSWORD=""
ADMIN_API_KEY=""                                 # optional header-based admin auth

# ── Comment Moderation ────────────────────────────────────
MODERATION_KEYWORDS=""                           # comma-separated blocked words
MODERATION_KEYWORD_ACTION="reject"               # "reject" or "hide"

# ── Background Ingestion ──────────────────────────────────
INGEST_ON_BOOT="false"                           # set to "true" to ingest topic library on startup
INGEST_CATEGORY=""                               # optional, restrict to one category
INGEST_LIMIT=""                                  # optional, max articles to ingest

# ── Code Runner ───────────────────────────────────────────
CODE_RUNNER_PROVIDER="piston"                    # only "piston" supported
CODE_RUNNER_API="https://emkc.org/api/v2/piston/execute"
CODE_RUNNER_DEFAULT_VERSION="latest"
CODE_RUNNER_COMPILE_TIMEOUT_MS="10000"
CODE_RUNNER_RUN_TIMEOUT_MS="3000"
CODE_RUNNER_JAVASCRIPT_VERSION=""
CODE_RUNNER_PYTHON_VERSION=""
CODE_RUNNER_JAVA_VERSION=""
CODE_RUNNER_CPP_VERSION=""

# ── App ───────────────────────────────────────────────────
APP_URL="MY_APP_URL"
PORT="4000"
